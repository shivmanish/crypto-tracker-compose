<?xml version="1.0" encoding="utf-8"?>
<!--
  Declares the languages this app ships. On Android 13+ (API 33) this powers the
  per-app language picker in system Settings → Apps → Crypto Tracker → Language.
  Flutter equivalent: the supportedLocales list on MaterialApp.
-->
<locale-config xmlns:android="http://schemas.android.com/apk/res/android">
    <locale android:name="en" />
    <locale android:name="hi" />
</locale-config>
